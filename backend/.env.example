FLASK_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production
TOKEN_SALT=midwest-docs-api
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=midwest_document_intelligence
ACCESS_TOKEN_TTL_SECONDS=3600
REFRESH_TOKEN_TTL_DAYS=30
MAX_UPLOAD_SIZE_MB=25
AUTO_LOGOUT_MINUTES=2
BUSINESS_HOURS_TIMEZONE=Asia/Kolkata
BUSINESS_HOURS_START_HOUR=7
BUSINESS_HOURS_END_HOUR=20
BUSINESS_HOURS_ALLOWED_DAYS=0,1,2,3,4
FAILED_LOGIN_LIMIT=5
FAILED_LOGIN_LOCK_MINUTES=15
SECURITY_HEADERS_ENABLED=true
ALLOWED_UPLOAD_EXTENSIONS=pdf,doc,docx,xls,xlsx,png,jpg,jpeg
ALLOWED_UPLOAD_CONTENT_TYPES=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,image/png,image/jpeg
DEFAULT_DEMO_PASSWORD=Password123!
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
AUTO_SEED_DEMO=false
